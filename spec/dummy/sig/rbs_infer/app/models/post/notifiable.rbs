class Post
  module Notifiable
    extend ActiveSupport::Concern
    def notification_title: () -> String
    def notify_subscribers: (untyped subscribers) -> untyped
    def notification_excerpt: (?Integer length) -> untyped
    def notification_payload: () -> { author_name: untyped, excerpt: untyped, post_id: untyped, published_at: untyped, title: untyped }
    def user_updated_at: () -> ActiveSupport::TimeWithZone

    private

    def deliver_notification: (untyped subscriber) -> { body: String, from: String, sent_at: ActiveSupport::TimeWithZone, to: String }
  end
end
