class User
  module Displayable
    extend ActiveSupport::Concern
    def initials: () -> String
    def display_name: () -> String
    def gravatar_url: (?Integer size) -> String
    def profile_summary: () -> { name: untyped, initials: untyped, posts_count: untyped, member_since: untyped }
    def short_bio: (?Integer max) -> String
  end
end
