#!/usr/bin/env ruby
# frozen_string_literal: true

require "rbs_infer"
require "fileutils"
require "optparse"

output = false
output_dir = "sig/generated"
max_passes = 10
files = []

parser = OptionParser.new do |opts|
  opts.banner = "Usage: rbs_infer [options] FILE_OR_DIR [...]"

  opts.on("--output", "Write RBS to sig/generated/ (based on source file path)") do
    output = true
  end

  opts.on("--output-dir DIR", "Output directory (default: sig/generated)") do |dir|
    output = true
    output_dir = dir
  end

  opts.on("--max-passes N", Integer, "Max iterative passes for type convergence (default: 10)") do |n|
    max_passes = n
  end

  opts.on("-v", "--version", "Show version") do
    puts "rbs_infer #{RbsInfer::VERSION}"
    exit
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end

parser.parse!
inputs = ARGV

if inputs.empty?
  puts parser
  exit 1
end

# Expandir diretórios para todos os .rb contidos neles (recursivamente)
files = inputs.flat_map do |input|
  if File.directory?(input)
    Dir[File.join(input, "**/*.rb")]
  else
    [input]
  end
end

if files.empty?
  warn "No .rb files found in: #{inputs.join(', ')}"
  exit 1
end

source_files = Dir["app/**/*.rb", "engines/**/*.rb", "lib/**/*.rb"]

rails_project = Gem::Specification.find_by_name("rails") rescue nil

if rails_project
  require "rbs_infer/extensions/rails/erb_caller_resolver"
  erb_caller_resolver = RbsInfer::Extensions::Rails::ErbCallerResolver.new(
    app_dir: Dir.pwd,
    source_files: source_files
  )
end

generate = lambda do |inputs_to_process, silent: false|
  changed_files = []

  inputs_to_process.each do |input|
    is_path = input.include?("/") || input.end_with?(".rb")
    args = if is_path
             { target_file: input, source_files: source_files }
           else
             { target_class: input, source_files: source_files }
           end

    if erb_caller_resolver && input.include?("helpers/")
      args[:extra_caller_sources] = erb_caller_resolver
    end

    analyzer = RbsInfer::Analyzer.new(**args)
    rbs = analyzer.generate_rbs

    unless rbs
      warn "#{input}: class not found or no members detected."
      next
    end

    if output
      source_path = analyzer.target_file || input
      output_path = File.join(output_dir, source_path.sub(/\.rb$/, ".rbs"))

      FileUtils.mkdir_p(File.dirname(output_path))

      new_content = rbs + "\n"
      old_content = File.exist?(output_path) ? File.read(output_path) : nil

      File.write(output_path, new_content)
      puts output_path unless silent

      changed_files << input if new_content != old_content
    else
      puts rbs
    end
  end

  changed_files
end

if output
  levels = RbsInfer::DependencySorter.sort(files)

  all_changed = []
  levels.each_with_index do |level_files, idx|
    # Reset Steep cache between levels so it picks up RBS from prior levels
    RbsInfer::SteepBridge.reset! if idx > 0
    changed = generate.call(level_files)
    all_changed.concat(changed)
  end

  # Stabilization: re-run any remaining changed files (handles cycles, indirect deps)
  pass = 1
  changed = all_changed.uniq
  while changed.any? && pass < max_passes
    pass += 1
    RbsInfer::SteepBridge.reset!
    changed = generate.call(changed, silent: true)
  end

  if changed.any?
    warn "Warning: types did not converge after #{max_passes} stabilization passes " \
         "(#{changed.size} files still changing). Try increasing --max-passes."
  end
else
  generate.call(files)
end
